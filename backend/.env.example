# ── Required ──────────────────────────────────────────────────────────────────
# Your Google AI Studio API key: https://aistudio.google.com/apikey
# Set this in Railway → your service → Variables tab (do NOT commit the real value)
GOOGLE_API_KEY=your_google_api_key_here

# ── Model config (optional — defaults shown) ──────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001

# ── Chunking (optional) ───────────────────────────────────────────────────────
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# ── Retrieval (optional) ──────────────────────────────────────────────────────
TOP_K=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# ── Storage (optional) ────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./vector_db
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads

# ── Chat (optional) ───────────────────────────────────────────────────────────
MAX_HISTORY_TURNS=6
